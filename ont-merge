#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $0 [-s OFFSET] RUN_DIR"
  echo "  -s OFFSET: barcode offset (default 1)"
  exit 1
}

OFFSET=1
while getopts ":s:" opt; do
  case $opt in
    s) OFFSET=$OPTARG ;;
    *) usage ;;
  esac
done
shift $((OPTIND-1))

RUN_DIR=${1:-}
[[ -d ${RUN_DIR:-} ]] || { echo "Run directory not found"; usage; }

KEEPERS=( $(seq -f "%02g" "$OFFSET" 96) )

find "$RUN_DIR" -type d -name fastq_pass | while read -r FASTQ_DIR; do
  SAMPLE_DIR=$(dirname "$FASTQ_DIR")
  MERGE_DIR="$SAMPLE_DIR/merged"
  mkdir -p "$MERGE_DIR"
  SAMPLE_NAME=$(basename "$SAMPLE_DIR")

  for BC in "${KEEPERS[@]}"; do
    OUT="$MERGE_DIR/${SAMPLE_NAME}_pass_barcode${BC}.fastq.gz"

    rm -f "$OUT"

    find "$FASTQ_DIR" -type f -name "*barcode${BC}*.fastq.gz" -print0 \
      | xargs -0r cat > "$OUT"
  done
done